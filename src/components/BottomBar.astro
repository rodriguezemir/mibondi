---
const tipoLabels: Record<string, string> = {
  desvio: "Desvío",
  paro: "Paro",
  novedad: "Novedad",
  corte: "Corte",
};

const tipoClasses: Record<string, string> = {
  desvio: "bg-amber-100 text-amber-800",
  paro: "bg-red-100 text-red-800",
  novedad: "bg-blue-100 text-blue-800",
  corte: "bg-yellow-100 text-yellow-800",
};

const noticias = [
  {
    id: 1,
    tipo: "desvio",
    titulo: "Línea 12 con desvío por obra en Av. Colón",
    descripcion:
      "Por trabajos de bacheo, la línea 12 no circula por Av. Colón entre Sucre y Santa Rosa. Tomar recorrido alternativo por Av. General Paz.",
    fecha: "2026-06-28T08:30:00",
  },
  {
    id: 2,
    tipo: "paro",
    titulo: "Paro de transporte previsto para el viernes",
    descripcion:
      "La UTA anunció un paro de 24 horas para el viernes 4 de julio. No habrá servicio de colectivo en toda la ciudad.",
    fecha: "2026-06-27T15:00:00",
  },
  {
    id: 3,
    tipo: "novedad",
    titulo: "Nueva parada en Barrio Cerro de las Rosas",
    descripcion:
      "Se incorporó la parada 4521 en la intersección de Av. Rafael Núñez y Tristán Malbrán. Disponible desde hoy para las líneas 30, 31 y 32.",
    fecha: "2026-06-26T09:15:00",
  },
  {
    id: 4,
    tipo: "corte",
    titulo: "Corte total en Av. Hipólito Yrigoyen",
    descripcion:
      "Por manifestación, corte total entre Rivadavia y San Martín. Recorridos alternativos: 14, 15, 22.",
    fecha: "2026-06-25T18:45:00",
  },
];

const colectivos = [
  { linea: 12, destino: "Plaza San Martín", minutos: 3, distancia: 120 },
  { linea: 30, destino: "Cerro de las Rosas", minutos: 5, distancia: 250 },
  { linea: 22, destino: "Barrio Alberdi", minutos: 7, distancia: 380 },
  { linea: 14, destino: "Terminal de Ómnibus", minutos: 10, distancia: 450 },
  { linea: 40, destino: "Nueva Córdoba", minutos: 12, distancia: 600 },
];
---

<div
  id="sheet"
  class="fixed z-10 inset-x-0 bottom-0 md:inset-x-auto md:inset-y-0 md:left-0 md:top-14 md:h-full! md:w-90 bg-white/90 backdrop-blur shadow-lg flex flex-col select-none touch-pan-y transition-[height] duration-200 ease-out md:transition-all"
  style="height: 25vh;"
>
  <button
    id="handle"
    type="button"
    aria-label="Arrastrar para redimensionar"
    class="md:hidden w-full h-6 flex items-center justify-center cursor-grab active:cursor-grabbing touch-none shrink-0"
  >
    <span class="block w-10 h-1.5 rounded-full bg-gray-400 animate-pulse"
    ></span>
  </button>

  <div class="flex flex-col gap-3 p-4 flex-1 min-h-0">
    <div role="tablist" class="flex border-b border-gray-200 -mx-4 px-4">
      <button
        type="button"
        role="tab"
        data-tab="navegacion"
        aria-selected="true"
        class="flex-1 py-2 transition-all text-sm font-semibold border-b-2 border-amber-700 text-amber-700 -mb-px"
      >
        Navegación
      </button>
      <button
        type="button"
        role="tab"
        data-tab="lineas"
        aria-selected="false"
        class="flex-1 py-2 transition-all text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700 -mb-px"
      >
        Líneas
      </button>
      <button
        type="button"
        role="tab"
        data-tab="noticias"
        aria-selected="false"
        class="flex-1 py-2 transition-all text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700 -mb-px"
      >
        Noticias
      </button>
    </div>

    <div data-panel="lineas" class="hidden flex-1 flex-col gap-3 min-h-0">
      <label class="sr-only" for="parada">Número de parada</label>
      <input
        id="parada"
        type="text"
        inputmode="numeric"
        placeholder="Número de parada..."
        class="w-full rounded-lg border border-gray-300 bg-white/80 px-3 py-2 text-base focus:outline-none focus:ring-2 focus:ring-amber-700"
      />

      <button
        id="lineas-back"
        type="button"
        aria-label="Volver a la lista de líneas"
        class="hidden self-start text-sm font-semibold text-amber-700 hover:text-amber-800 flex items-center gap-1"
      >
        <span aria-hidden="true">←</span>
        <span>Todas las líneas</span>
      </button>

      <div
        id="lineas-grid"
        class="mt-5 min-h-0 flex-1 overflow-y-auto overscroll-contain grid grid-cols-5 md:grid-cols-3 gap-2 content-start"
      >
        <p class="col-span-full text-center text-sm text-gray-500 py-4">
          Cargando líneas...
        </p>
      </div>
    </div>

    <div
      data-panel="noticias"
      class="hidden flex-1 overflow-y-auto flex-col gap-3 min-h-0"
    >
      {
        noticias.map((n, i) => (
          <article
            class="animate-fade-in-up rounded-xl border border-gray-200 bg-white/70 p-3 flex flex-col gap-1.5"
            style={`animation-delay: ${i * 100}ms`}
          >
            <div class="flex items-center justify-between gap-2">
              <span
                class={`text-[10px] font-bold uppercase tracking-wide px-1.5 py-0.5 rounded ${tipoClasses[n.tipo]}`}
              >
                {tipoLabels[n.tipo]}
              </span>
              <time data-fecha={n.fecha} class="text-xs text-gray-500">
                {n.fecha}
              </time>
            </div>
            <h3 class="font-bold text-sm leading-snug">{n.titulo}</h3>
            <p class="text-xs text-gray-600 leading-snug">{n.descripcion}</p>
          </article>
        ))
      }
    </div>

    <div
      data-panel="navegacion"
      class="flex-1 overflow-y-auto flex-col gap-4 min-h-0"
    >
      <label class="sr-only" for="destino">¿A dónde vamos?</label>
      <input
        id="destino"
        type="text"
        placeholder="¿A dónde vamos?"
        class="w-full rounded-lg border border-gray-300 bg-white/80 px-3 py-2 text-base focus:outline-none focus:ring-2 focus:ring-amber-700"
      />

      <section>
        <h3
          class="mt-10 text-xs font-bold uppercase tracking-wide text-gray-500 mb-2"
        >
          Colectivos cerca
        </h3>
        <ul class="flex flex-col gap-2">
          {
            colectivos.map((c, i) => (
              <li
                class="animate-fade-in-up"
                style={`animation-delay: ${i * 80}ms`}
              >
                <button
                  type="button"
                  class="w-full text-left rounded-xl border border-gray-200 bg-white/70 p-3 hover:bg-white transition-colors"
                >
                  <div class="flex items-center gap-3">
                    <span class="shrink-0 bg-amber-700 text-white rounded-lg w-10 h-10 flex items-center justify-center font-black">
                      {c.linea}
                    </span>
                    <div class="flex-1 min-w-0">
                      <p class="font-semibold text-sm truncate">{c.destino}</p>
                      <p class="text-xs text-gray-500">
                        Llega en {c.minutos} min · a {c.distancia} m
                      </p>
                    </div>
                  </div>
                </button>
              </li>
            ))
          }
        </ul>
      </section>

      <section>
        <h3
          class="text-xs mt-10 font-bold uppercase tracking-wide text-gray-500 mb-2"
        >
          Noticias relevantes
        </h3>
        <div class="flex flex-col gap-3">
          {
            noticias.slice(0, 2).map((n, i) => (
              <article
                class="animate-fade-in-up rounded-xl border border-gray-200 bg-white/70 p-3 flex flex-col gap-1.5"
                style={`animation-delay: ${i * 100}ms`}
              >
                <div class="flex items-center justify-between gap-2">
                  <span
                    class={`text-[10px] font-bold uppercase tracking-wide px-1.5 py-0.5 rounded ${tipoClasses[n.tipo]}`}
                  >
                    {tipoLabels[n.tipo]}
                  </span>
                  <time data-fecha={n.fecha} class="text-xs text-gray-500">
                    {n.fecha}
                  </time>
                </div>
                <h4 class="font-bold text-sm leading-snug">{n.titulo}</h4>
              </article>
            ))
          }
        </div>
      </section>
    </div>
  </div>
</div>

<script>
  const sheet = document.getElementById("sheet");
  const handle = document.getElementById("handle");

  if (sheet && handle) {
    const isDesktop = () => window.matchMedia("(min-width: 768px)").matches;
    const setHeight = (px: number) => {
      sheet.style.height = `${px}px`;
    };

    const snaps = () => {
      const vh = window.innerHeight;
      return [vh * 0.25, vh * 0.5, vh * 0.85];
    };

    const snapToClosest = () => {
      const current = sheet.getBoundingClientRect().height;
      const [s1, s2, s3] = snaps();
      const closest = [s1, s2, s3].reduce((a, b) =>
        Math.abs(b - current) < Math.abs(a - current) ? b : a,
      );
      setHeight(closest);
      sheet.dataset.lastH = String(closest);
    };

    let dragging = false;
    let startY = 0;
    let startH = 0;

    const onDown = (e: { clientY: number; pointerId: number }) => {
      if (isDesktop()) return;
      dragging = true;
      startY = e.clientY;
      startH = sheet.getBoundingClientRect().height;
      handle.setPointerCapture(e.pointerId);
      sheet.style.transition = "none";
    };

    const onMove = (e: { clientY: number }) => {
      if (!dragging) return;
      const delta = startY - e.clientY;
      const maxH = window.innerHeight * 0.9;
      const newH = Math.max(80, Math.min(maxH, startH + delta));
      setHeight(newH);
    };

    const onUp = (e: { pointerId: number }) => {
      if (!dragging) return;
      dragging = false;
      try {
        handle.releasePointerCapture(e.pointerId);
      } catch {}
      sheet.style.transition = "";
      snapToClosest();
    };

    handle.addEventListener("pointerdown", onDown);
    handle.addEventListener("pointermove", onMove);
    handle.addEventListener("pointerup", onUp);
    handle.addEventListener("pointercancel", onUp);

    const mq = window.matchMedia("(min-width: 768px)");
    mq.addEventListener("change", () => {
      if (mq.matches) {
        sheet.style.height = "";
      } else if (sheet.dataset.lastH) {
        setHeight(Number(sheet.dataset.lastH));
      }
    });
  }

  const tabs = document.querySelectorAll<HTMLButtonElement>('[role="tab"]');
  const panels = document.querySelectorAll<HTMLDivElement>("[data-panel]");

  tabs.forEach((t) => {
    t.addEventListener("click", () => {
      const target = t.dataset.tab;
      tabs.forEach((x) => {
        const active = x === t;
        x.setAttribute("aria-selected", active ? "true" : "false");
        x.classList.toggle("border-amber-700", active);
        x.classList.toggle("text-amber-700", active);
        x.classList.toggle("border-transparent", !active);
        x.classList.toggle("text-gray-500", !active);
      });
      panels.forEach((p) => {
        p.classList.toggle("hidden", p.dataset.panel !== target);
      });
    });
  });

  const formatRelativa = (iso: string) => {
    const then = new Date(iso);
    const now = new Date();
    const diff = (now.getTime() - then.getTime()) / 1000;
    if (diff < 60) return "hace un momento";
    if (diff < 3600) return `hace ${Math.floor(diff / 60)} min`;
    if (diff < 86400) return `hace ${Math.floor(diff / 3600)} h`;
    if (diff < 604800) return `hace ${Math.floor(diff / 86400)} d`;
    return then.toLocaleDateString("es-AR", {
      day: "2-digit",
      month: "short",
    });
  };

  document
    .querySelectorAll<HTMLTimeElement>("time[data-fecha]")
    .forEach((el) => {
      const iso = el.dataset.fecha;
      if (iso) el.textContent = formatRelativa(iso);
    });

  interface Linea {
    linea_id: string;
    short_name: string;
    long_name: string;
    agency_id: string;
    color: string;
    text_color: string;
  }

  interface Ruta {
    ruta_id: string;
    linea_id: string;
    route_id: string;
    headsign: string;
    direction: number;
    shape_id: string;
    agency_id: string;
  }

  const API_BASE = "http://localhost:8080";

  const escapeHtml = (s: string): string =>
    s.replace(
      /[&<>"']/g,
      (c) =>
        ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[c] as string,
    );

  const grid = document.getElementById("lineas-grid")!;
  const backBtn = document.getElementById("lineas-back")!;

  let lineasData: Linea[] = [];

  const LINEAS_CLASSES =
    "mt-5 min-h-0 flex-1 overflow-y-auto overscroll-contain grid grid-cols-5 md:grid-cols-3 gap-2 content-start";
  const RUTAS_CLASSES =
    "mt-5 min-h-0 flex-1 overflow-y-auto overscroll-contain flex flex-col gap-2";

  const lookupLineaColor = (
    lineaId: string | undefined,
    agencyId: string | undefined,
  ): string => {
    if (!lineaId) return "#b45309";
    const linea = lineasData.find(
      (l) =>
        l.linea_id === lineaId &&
        (agencyId ? l.agency_id === agencyId : true),
    );
    if (linea?.color && linea.color.trim() !== "") return `#${linea.color}`;
    return "#b45309";
  };

  const renderLineasView = () => {
    grid.className = LINEAS_CLASSES;
    grid.innerHTML = lineasData
      .map((l, i) => {
        const bg = l.color && l.color.trim() !== "" ? `#${l.color}` : "#a16207";
        const delay = Math.min(i * 15, 500);
        return `
          <button
            type="button"
            class="mibondi-linea-btn animate-fade-in-up text-white rounded-xl py-1.5 font-semibold transition-colors"
            style="background-color: ${bg}; animation-delay: ${delay}ms"
            data-linea-id="${escapeHtml(l.linea_id)}"
          >
            ${escapeHtml(l.short_name)}
          </button>
        `;
      })
      .join("");

    grid
      .querySelectorAll<HTMLButtonElement>(".mibondi-linea-btn")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const id = btn.dataset.lineaId;
          if (id) showRutasView(id);
        });
      });
  };

  const renderRutasView = async (lineaId: string) => {
    grid.className = RUTAS_CLASSES;
    grid.innerHTML =
      '<p class="text-center text-sm text-gray-500 py-4">Cargando rutas...</p>';

    try {
      const res = await fetch(
        `${API_BASE}/api/rutas/${encodeURIComponent(lineaId)}`,
      );
      if (res.status === 404) {
        grid.innerHTML =
          '<p class="text-center text-sm text-gray-500 py-4">No hay rutas para esta línea.</p>';
        return;
      }
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const rutas = (await res.json()) as Ruta[];

      if (rutas.length === 0) {
        grid.innerHTML =
          '<p class="text-center text-sm text-gray-500 py-4">No hay rutas para esta línea.</p>';
        return;
      }

      grid.innerHTML = rutas
        .map((r, i) => {
          const dirLabel = r.direction === 0 ? "Ida" : "Vuelta";
          const delay = Math.min(i * 30, 300);
          return `
            <button
              type="button"
              class="mibondi-ruta-btn animate-fade-in text-left rounded-xl border border-gray-200 bg-white/80 p-3 hover:bg-white transition-colors"
              data-shape-id="${escapeHtml(r.shape_id)}"
              data-ruta-id="${escapeHtml(r.ruta_id)}"
              data-direction="${r.direction}"
              data-linea-id="${escapeHtml(r.linea_id)}"
              data-agency-id="${escapeHtml(r.agency_id)}"
              style="animation-delay: ${delay}ms"
            >
              <div class="flex items-center gap-3">
                <span class="shrink-0 bg-amber-700 text-white rounded-lg px-2.5 h-10 flex items-center justify-center text-[10px] font-bold uppercase tracking-wide">
                  ${dirLabel}
                </span>
                <span class="font-medium text-sm flex-1">${escapeHtml(r.headsign)}</span>
              </div>
            </button>
          `;
        })
        .join("");

      grid.querySelectorAll<HTMLButtonElement>(".mibondi-ruta-btn").forEach(
        (btn) => {
          btn.addEventListener("click", () => {
            const shapeId = btn.dataset.shapeId;
            const rutaId = btn.dataset.rutaId;
            const lineaId = btn.dataset.lineaId;
            const agencyId = btn.dataset.agencyId;
            if (!shapeId) return;
            const color = lookupLineaColor(lineaId, agencyId);
            window.dispatchEvent(
              new CustomEvent("mibondi:ruta-selected", {
                detail: { shapeId, rutaId, color },
              }),
            );
          });
        },
      );
    } catch (err) {
      grid.innerHTML = `<p class="text-center text-sm text-red-600 py-4">No se pudieron cargar las rutas: ${escapeHtml((err as Error).message)}</p>`;
    }
  };

  const showLineasView = () => {
    backBtn.classList.add("hidden");
    renderLineasView();
    window.dispatchEvent(new CustomEvent("mibondi:ruta-cleared"));
  };

  const showRutasView = (lineaId: string) => {
    backBtn.classList.remove("hidden");
    void renderRutasView(lineaId);
  };

  backBtn.addEventListener("click", showLineasView);

  const loadLineas = async () => {
    try {
      const res = await fetch(`${API_BASE}/api/lineas`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const lineas = (await res.json()) as Linea[];
      lineasData = lineas.filter(
        (l) => l.short_name && l.short_name.trim() !== "",
      );

      if (lineasData.length === 0) {
        grid.innerHTML =
          '<p class="col-span-full text-center text-sm text-gray-500 py-4">No hay líneas disponibles.</p>';
        return;
      }

      renderLineasView();
    } catch (err) {
      grid.innerHTML = `<p class="col-span-full text-center text-sm text-red-600 py-4">No se pudieron cargar las líneas: ${escapeHtml((err as Error).message)}</p>`;
    }
  };

  loadLineas();
</script>

<style is:global>
  .mibondi-linea-btn:hover {
    filter: brightness(0.92);
  }
  .mibondi-linea-btn:active {
    filter: brightness(0.84);
  }

  #lineas-grid {
    scrollbar-width: thin;
    scrollbar-color: rgb(180 83 9 / 0.4) transparent;
  }
  #lineas-grid::-webkit-scrollbar {
    width: 6px;
  }
  #lineas-grid::-webkit-scrollbar-track {
    background: transparent;
  }
  #lineas-grid::-webkit-scrollbar-thumb {
    background-color: rgb(180 83 9 / 0.35);
    border-radius: 9999px;
  }
  #lineas-grid::-webkit-scrollbar-thumb:hover {
    background-color: rgb(180 83 9 / 0.6);
  }
</style>
